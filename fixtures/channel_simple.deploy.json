{
  "version": "0.9.0",
  "bindings": {
    "identity": {
      "provider": "stub",
      "config": {}
    },
    "storage": {
      "provider": "sqlite",
      "config": {}
    },
    "presentation": {
      "provider": "default",
      "config": {}
    },
    "compute": {},
    "channels": {
      "note-sync": {
        "provider": "stub",
        "config": {
          "target": "https://TODO-configure-note_sync.example.com/hook",
          "timeout_ms": 10000,
          "auth": {
            "type": "bearer",
            "token": "${NOTE_SYNC_TOKEN}"
          }
        }
      },
      "echo-receiver": {
        "provider": "stub",
        "config": {
          "url": "https://TODO-configure-echo_receiver.example.com/api",
          "protocol": "http",
          "auth": {
            "type": "bearer",
            "token": "${ECHO_RECEIVER_TOKEN}"
          },
          "timeout_ms": 30000,
          "retry": {
            "max_attempts": 3,
            "backoff_ms": 1000
          }
        }
      }
    }
  },
  "runtime": {}
}
{
  "version": "0.9.0",
  "bindings": {
    "identity": {
      "provider": "stub",
      "config": {}
    },
    "storage": {
      "provider": "sqlite",
      "config": {}
    },
    "presentation": {
      "provider": "default",
      "config": {}
    },
    "compute": {},
    "channels": {
      "order webhook": {
        "provider": "stub",
        "config": {
          "url": "https://TODO-configure-order_webhook.example.com/api",
          "protocol": "http",
          "auth": {
            "type": "bearer",
            "token": "${ORDER_WEBHOOK_TOKEN}"
          },
          "timeout_ms": 30000,
          "retry": {
            "max_attempts": 3,
            "backoff_ms": 1000
          }
        }
      },
      "order updates stream": {
        "provider": "stub",
        "config": {
          "target": "https://TODO-configure-order_updates_stream.example.com/hook",
          "timeout_ms": 10000,
          "auth": {
            "type": "bearer",
            "token": "${ORDER_UPDATES_STREAM_TOKEN}"
          }
        }
      },
      "order notifications": {
        "provider": "stub",
        "config": {
          "workspace_token_ref": "${ORDER_NOTIFICATIONS_TOKEN}",
          "target": "TODO-configure-order_notifications-channel"
        }
      }
    }
  },
  "runtime": {}
}
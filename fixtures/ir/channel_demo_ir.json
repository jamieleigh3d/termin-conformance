  "computes": [
    {
      "name": {
        "display": "classify-alert",
        "snake": "classify_alert",
        "pascal": "ClassifyAlert"
      },
      "shape": "TRANSFORM",
      "input_content": [
        "alerts"
      ],
      "output_content": [
        "incidents"
      ],
      "body_lines": [
        "incident.title = alert.monitor_name + \" threshold breached\"",
        "incident.severity = alert.current_value > alert.threshold * 2 ? \"critical\" : alert.current_value > alert.threshold * 1.5 ? \"high\" : \"medium\"",
        "incident.source = \"monitoring\"",
        "incident.affected_service = alert.monitor_name",
        "incident.summary = alert.metric + \" at \" + string(alert.current_value) + \" (threshold: \" + string(alert.threshold) + \")\""
      ],
      "required_scope": "incidents.manage",
      "required_role": null,
      "input_params": [
        {
          "name": "alert",
          "type_name": "alerts"
        }
      ],
      "output_params": [
        {
          "name": "incident",
          "type_name": "incidents"
        }
      ],

      "preconditions": [
        "Compute.Scopes.contains(\"findings.remediate\")"
      ],
      "postconditions": [
        "After.content_query(\"findings\").filter(f, f.remediation == \"detected\").size() <= Before.content_query(\"findings\").filter(f, f.remediation == \"detected\").size()"
      ],
      "directive": null,
      "objective": "You are a remediation agent. Attempt safe auto-remediation for\n    security findings. Only act where the fix is deterministic and\n    reversible. Flag for human review if judgment is needed.",
      "strategy": "1. Read the finding and classify:\n       - iam-drift: use channel.invoke(\"security-tools\", \"restrict-policy\")\n         to narrow the IAM policy to expected permissions\n       - stale-secret: use channel.invoke(\"security-tools\", \"rotate-secret\")\n         to rotate the expired credential\n       - confidentiality-violation: flag for human (requires definition change)\n       - cve, state-deadlock, error-spike: flag for human\n    2. For auto-remediable: state.transition(finding, \"auto-fix-applied\")\n    3. For human-required: state.transition(finding, \"flagged-for-human\")",
      "trigger": "event \"finding.created\"",
      "trigger_where": null,

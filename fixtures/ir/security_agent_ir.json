      "postconditions": [
        "After.content_query(\"findings\").size() <= Before.content_query(\"findings\").size() + 100"
      ],
      "directive": null,
      "objective": "You are a security scanning agent for the app fabric.\n    Scan all deployed apps for IAM policy drift, dependency CVEs,\n    confidentiality violations, and stale secrets. Create a finding\n    for each issue detected. Prioritize internet-facing apps over\n    internal, production over beta.",
      "strategy": "1. Use reflect.apps() to list all active apps\n    2. For each app:\n       a. Use reflect.app(name).definition to load its definition\n       b. Use channel.invoke(\"security-tools\", \"describe-iam-policy\") to get current policy\n       c. Compare expected vs actual IAM policy\n       d. Check dependency CVEs and secret rotation age\n    3. Use content.create(\"findings\", ...) for each issue found\n    4. Use content.create(\"scan-runs\", ...) to record this execution",
      "trigger": "schedule every 1 hour",
      "trigger_where": null,
      "accesses": [],
      "input_fields": [],
      "output_fields": [],
      "output_creates": null,
      "audit_level": "debug",
      "audit_scope": "findings.remediate",
      "audit_content_ref": "compute_audit_log_scanner"
    },
    {
      "name": {
        "display": "remediator",
        "snake": "remediator",
        "pascal": "Remediator"
      },

{
  "version": "0.9.0",
  "bindings": {
    "identity": {
      "provider": "stub",
      "config": {}
    },
    "storage": {
      "provider": "sqlite",
      "config": {}
    },
    "presentation": {
      "provider": "default",
      "config": {}
    },
    "compute": {
      "scanner": {
        "provider": "anthropic",
        "config": {
          "model": "claude-haiku-4-5-20251001",
          "api_key": "${ANTHROPIC_API_KEY}"
        }
      },
      "remediator": {
        "provider": "anthropic",
        "config": {
          "model": "claude-haiku-4-5-20251001",
          "api_key": "${ANTHROPIC_API_KEY}"
        }
      }
    },
    "channels": {
      "security-tools": {
        "provider": "stub",
        "config": {
          "target": "https://TODO-configure-security_tools.example.com/hook",
          "timeout_ms": 10000,
          "auth": {
            "type": "bearer",
            "token": "${SECURITY_TOOLS_TOKEN}"
          }
        }
      },
      "slack": {
        "provider": "stub",
        "config": {
          "workspace_token_ref": "${SLACK_TOKEN}",
          "target": "TODO-configure-slack-channel"
        }
      }
    }
  },
  "runtime": {}
}